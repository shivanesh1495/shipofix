generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// Unified shipping rule store.
///
/// Zone-wise rules (one-by-one editing in the dashboard) use the real
/// Shopify delivery-zone GID as `deliveryZoneGid`. Excel-imported rules
/// use a synthetic identifier prefixed with `bulk:` (e.g. `bulk:express-au`).
///
/// Both kinds live side-by-side in this table — the carrier service
/// matches incoming checkout requests against ALL rules by country
/// coverage, irrespective of origin. Editing, viewing, and deleting from
/// the Rules Overview tab works the same for both.
model ZoneRule {
  id              String   @id @default(cuid())
  shop            String
  deliveryZoneGid String
  name            String
  logicType       String   @default("STANDARD_TIER")
  currency        String   @default("USD")
  rulesJson       String   @default("{}")
  countries       String?
  /// "shopify" for zone-wise rules, "bulk" for Excel-imported rules.
  /// Lets the UI / upload action distinguish the two without parsing GIDs.
  source          String   @default("shopify")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, deliveryZoneGid])
  @@index([shop, updatedAt])
  @@index([shop, source])
}

model AppSetting {
  shop      String   @id
  /// "free" | "advanced" | "premium". Null = user hasn't picked a plan yet,
  /// gates the dashboard behind /app/subscription on first load.
  ///
  /// IMPORTANT (billing): this column is the CACHED paid ENTITLEMENT, not just a
  /// UI choice. It is kept in sync with the shop's real Shopify Billing API
  /// subscription by reconcileEntitlement() (on every dashboard load) and the
  /// app_subscriptions/update webhook, so every `getShopPlan`-based gate across
  /// the app enforces payment with no extra checks. The truth lives in Shopify;
  /// a lapsed/cancelled subscription is downgraded to "free" on the next load.
  /// See app/lib/billing.server.js.
  plan      String?

  /* ── Legacy billing columns (UNUSED) ──
     Left in place from a previous off-platform (Razorpay) billing experiment
     that was removed in favour of the Shopify Billing API. All nullable and
     no longer read or written by any code. Kept to avoid a destructive
     migration; safe to drop in a future migration. */
  billingStatus           String?
  billingPlan             String?
  razorpaySubscriptionId  String?
  razorpayCustomerId      String?
  billingCurrentPeriodEnd DateTime?
  billingUpdatedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razorpaySubscriptionId])
}

model BulkEditUpload {
  shop       String   @id
  filename   String
  size       Int
  data       Bytes
  uploadedAt DateTime @default(now())
}
