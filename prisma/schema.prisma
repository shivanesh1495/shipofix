generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

/// Unified shipping rule store.
///
/// Zone-wise rules (one-by-one editing in the dashboard) use the real
/// Shopify delivery-zone GID as `deliveryZoneGid`. Excel-imported rules
/// use a synthetic identifier prefixed with `bulk:` (e.g. `bulk:express-au`).
///
/// Both kinds live side-by-side in this table — the carrier service
/// matches incoming checkout requests against ALL rules by country
/// coverage, irrespective of origin. Editing, viewing, and deleting from
/// the Rules Overview tab works the same for both.
model ZoneRule {
  id              String   @id @default(cuid())
  shop            String
  deliveryZoneGid String
  name            String
  logicType       String   @default("STANDARD_TIER")
  currency        String   @default("USD")
  rulesJson       String   @default("{}")
  countries       String?
  /// "shopify" for zone-wise rules, "bulk" for Excel-imported rules.
  /// Lets the UI / upload action distinguish the two without parsing GIDs.
  source          String   @default("shopify")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([shop, deliveryZoneGid])
  @@index([shop, updatedAt])
  @@index([shop, source])
}

model AppSetting {
  shop      String   @id
  /// "free" | "advanced" | "premium". Null = user hasn't picked a plan yet,
  /// gates the dashboard behind /app/subscription on first load.
  ///
  /// IMPORTANT (billing): when BILLING_ENABLED=true this column is the paid
  /// ENTITLEMENT, not just a UI choice. A paid tier (advanced/premium) is
  /// written here ONLY after Razorpay confirms payment via webhook, so every
  /// existing `getShopPlan`-based gate across the app enforces payment with no
  /// extra checks. When billing is disabled the picker writes it directly
  /// (current behaviour). See app/lib/billing.server.js.
  plan      String?

  /* ── Razorpay billing columns (dormant until BILLING_ENABLED=true) ──
     All nullable so they're a no-op for the current free-for-all mode; the
     billing code in app/lib/billing.server.js is the only reader/writer. */
  /// "active" | "pending" | "cancelled" | null. Source of truth for whether a
  /// paid subscription is currently entitling this shop.
  billingStatus           String?
  /// The paid tier the Razorpay subscription is for ("advanced"|"premium").
  billingPlan             String?
  /// Razorpay subscription id (sub_xxx) — used to reconcile webhook events.
  razorpaySubscriptionId  String?
  /// Razorpay customer id (cust_xxx), if a customer was created.
  razorpayCustomerId      String?
  /// End of the currently-paid billing period (from subscription.charged).
  billingCurrentPeriodEnd DateTime?
  /// Last time any billing column changed — for support/debugging.
  billingUpdatedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([razorpaySubscriptionId])
}

model BulkEditUpload {
  shop       String   @id
  filename   String
  size       Int
  data       Bytes
  uploadedAt DateTime @default(now())
}
